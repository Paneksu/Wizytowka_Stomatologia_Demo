---
const hours = [
  { days: 'Poniedziałek – Czwartek', time: '8:00 – 19:00' },
  { days: 'Piątek', time: '8:00 – 15:00' },
  { days: 'Sobota – Niedziela', time: 'zamknięte' },
];

---

<section id="kontakt" class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">

      <!-- lewa: nagłówek + dane -->
      <div class="flex flex-col gap-10">
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-5">Kontakt</p>
          <h2 class="font-display text-4xl lg:text-5xl font-semibold text-ink leading-[1.1] mb-6">
            Umów wizytę<br /><em class="italic font-normal">już dziś</em>
          </h2>
          <p class="text-sm text-ink-muted leading-relaxed max-w-md">
            Zadzwoń — oddzwonimy najszybciej jak to możliwe.
            Pierwsza wizyta kontrolna <strong class="text-ink font-medium">bezpłatna</strong>.
          </p>
        </div>

        <div class="flex flex-col gap-5">
          <a href="tel:+48324731902" class="flex items-start gap-4 group">
            <div class="mt-0.5 w-9 h-9 rounded-full bg-ink/8 flex items-center justify-center flex-shrink-0 group-hover:bg-gold/15 transition-colors duration-200">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-gold">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11 19.79 19.79 0 01.01 2.4 2 2 0 012 .18h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-ink-muted mb-0.5">Telefon</p>
              <p class="text-sm font-semibold text-ink group-hover:text-gold transition-colors duration-200">+48 32 47 31 902</p>
              <a href="tel:+48533311699" class="text-sm text-ink-muted hover:text-gold transition-colors duration-200 block mt-0.5">+48 533 311 699</a>
            </div>
          </a>

          <div class="flex items-start gap-4">
            <div class="mt-0.5 w-9 h-9 rounded-full bg-ink/8 flex items-center justify-center flex-shrink-0">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-gold">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-ink-muted mb-0.5">Adres</p>
              <p class="text-sm font-semibold text-ink">ul. Harcerska 2A</p>
              <p class="text-sm text-ink-muted">44-335 Jastrzębie-Zdrój</p>
              <p class="text-xs text-ink-muted mt-0.5">Pasaż 24H · parking przy wejściu</p>
            </div>
          </div>
        </div>

        <div class="border-t border-border pt-8">
          <p class="text-xs font-semibold tracking-[0.15em] uppercase text-ink-muted mb-4">Godziny otwarcia</p>
          <div class="flex flex-col gap-2.5">
            {hours.map(h => (
              <div class="flex items-center justify-between gap-x-3 text-sm flex-wrap">
                <span class="text-ink-muted">{h.days}</span>
                <span class={`font-medium ${h.time === 'zamknięte' ? 'text-ink-muted' : 'text-ink'}`}>{h.time}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- prawa: mapa -->
      <div class="rounded-2xl overflow-hidden border border-border h-full min-h-[400px]">
        <iframe
          src="https://maps.google.com/maps?q=ul.+Harcerska+2A,+Jastrz%C4%99bie-Zdr%C3%B3j&output=embed&hl=pl"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Gabinet Stomatologiczny w Pasażu 24H — mapa"
        ></iframe>
      </div>

    </div>
  </div>
</section>
