---
const links = [
  { href: '#uslugi', label: 'Usługi' },
  { href: '#o-nas', label: 'O nas' },
  { href: '#zespol', label: 'Zespół' },
  { href: '#galeria', label: 'Galeria' },
  { href: '#kontakt', label: 'Kontakt' },
];
---

<footer class="bg-ink text-cream/70">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 py-14 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 pb-10 border-b border-cream/10">
      <div class="flex flex-col gap-4">
        <a href="#" class="flex items-center gap-2.5">
          <img
            src="/images/logo_small-100x99.png"
            alt="Dentus Stomatologia"
            class="w-8 h-8 object-contain brightness-0 invert opacity-80"
          />
          <span class="text-base font-semibold text-gold tracking-tight">Dentus</span><span class="text-base font-light text-cream tracking-tight"> Stomatologia</span>
        </a>
        <p class="text-sm leading-relaxed max-w-xs">
          Profesjonalna opieka stomatologiczna dla całej rodziny.
          ul. Harcerska 2A, Jastrzębie-Zdrój.
        </p>
        <a
          href="https://www.facebook.com/Gabinet-Stomatologiczny-w-Pasa%C5%BCu-24h-1928603254134971/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="w-8 h-8 rounded-full bg-cream/8 flex items-center justify-center hover:bg-cream/15 transition-colors duration-200 self-start"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
          </svg>
        </a>
      </div>

      <div class="flex flex-col gap-3">
        <p class="text-xs font-semibold tracking-[0.15em] uppercase text-cream/40 mb-1">Nawigacja</p>
        {links.map(l => (
          <a href={l.href} class="text-sm hover:text-cream transition-colors duration-200">{l.label}</a>
        ))}
      </div>

      <div class="flex flex-col gap-3">
        <p class="text-xs font-semibold tracking-[0.15em] uppercase text-cream/40 mb-1">Dane kontaktowe</p>
        <p class="text-sm">ul. Harcerska 2A<br />44-335 Jastrzębie-Zdrój</p>
        <a href="tel:+48324731902" class="text-sm hover:text-cream transition-colors duration-200">+48 32 47 31 902</a>
        <a href="tel:+48533311699" class="text-sm hover:text-cream transition-colors duration-200">+48 533 311 699</a>
        <div class="pt-2 text-xs">
          <p class="text-cream/40 mb-1">Pon – Czw: 8:00–19:00</p>
          <p class="text-cream/40">Pt: 8:00–15:00</p>
        </div>
      </div>
    </div>

    <div class="pt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-xs text-cream/35">
      <p>&copy; {new Date().getFullYear()} Gabinet Stomatologiczny w Pasażu 24H. Wszelkie prawa zastrzeżone.</p>
      <div class="flex gap-5">
        <a href="#" class="hover:text-cream/60 transition-colors duration-200">Polityka prywatności</a>
      </div>
    </div>
  </div>
</footer>
