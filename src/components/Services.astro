---

<section id="uslugi" class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-14">
      <div class="max-w-xl">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4">Nasze usługi</p>
        <h2 class="font-display text-4xl lg:text-5xl font-semibold text-ink leading-[1.1]">
          Kompleksowa opieka<br /><em class="italic font-normal">pod jednym dachem</em>
        </h2>
      </div>
      <a
        href="#kontakt"
        class="hidden lg:inline-flex items-center gap-2 text-sm font-medium text-ink border border-border rounded-full px-6 py-3 hover:bg-cream-dark transition-colors duration-200"
      >
        Umów konsultację
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>

    <div class="relative" id="services-container">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-border rounded-2xl overflow-hidden">
        {services.map(s => (
          <div class="service-card bg-cream p-6 sm:p-8 lg:p-10 flex flex-col gap-5 transition-colors duration-300 group" data-card-id={s.id}>
            <div class="text-gold" set:html={s.icon} />
            <div class="flex-1">
              <h3 class="text-base font-semibold text-ink mb-2">{s.title}</h3>
              <p class="text-sm text-ink-muted leading-relaxed">{s.body}</p>
            </div>
            <div class="flex items-center justify-between pt-2 border-t border-border">
              <span class="text-xs font-semibold text-gold">{s.price}</span>
              <button
                class="show-prices-btn text-xs font-medium text-ink-muted hover:text-ink flex items-center gap-1.5 transition-colors duration-200 cursor-pointer"
                data-service-id={s.id}
                aria-label={`Zobacz ceny — ${s.title}`}
              >
                Zobacz ceny
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </button>
            </div>
          </div>
        ))}
      </div>

      {services.map(s => (
        <div
          class="price-panel absolute bg-cream rounded-2xl z-20 overflow-hidden"
          data-panel-id={s.id}
          style="display:none; top:0; left:0; right:0; bottom:0;"
        >
          <div class="h-full overflow-y-auto p-6 lg:p-8">
            <div class="flex items-start justify-between gap-4 mb-5">
              <div>
                <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-1">Cennik</p>
                <h3 class="text-2xl font-semibold text-ink">{s.title}</h3>
              </div>
              <button
                class="close-prices-btn flex-shrink-0 w-9 h-9 rounded-full bg-ink/8 hover:bg-ink/15 transition-colors duration-200 flex items-center justify-center text-ink"
                aria-label="Zamknij cennik"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-5">
              {s.priceGroups.map(group => (
                <div>
                  <p class="text-xs font-semibold tracking-[0.15em] uppercase text-ink-muted mb-2">{group.label}</p>
                  <div class="flex flex-col divide-y divide-border">
                    {group.items.map(item => (
                      <div class="flex items-baseline justify-between gap-3 py-1.5">
                        <span class="text-xs text-ink leading-snug">{item.name}</span>
                        <span class="text-xs font-semibold text-gold whitespace-nowrap flex-shrink-0">{item.price}</span>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>

            <div class="mt-4 pt-4 border-t border-border flex items-center justify-between gap-4">
              <p class="text-xs text-ink-muted">Ceny mają charakter orientacyjny. Ostateczna wycena na podstawie badania.</p>
              <a href="#kontakt" class="flex-shrink-0 bg-ink text-cream text-xs font-medium px-5 py-2.5 rounded-full hover:bg-ink/80 transition-colors duration-200">
                Umów wizytę
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const container = document.getElementById('services-container')!;
  const EASING = 'cubic-bezier(0.4, 0, 0.2, 1)';
  const NAV_H = 64;

  const isMobile = () => window.innerWidth < 768;

  function openPanel(id: string) {
    const card = container.querySelector<HTMLElement>(`[data-card-id="${id}"]`)!;
    const panel = container.querySelector<HTMLElement>(`[data-panel-id="${id}"]`)!;

    if (isMobile()) {
      Object.assign(panel.style, {
        position: 'fixed',
        top: NAV_H + 'px',
        left: '0',
        right: '0',
        bottom: '0',
        borderRadius: '0',
        zIndex: '40',
        display: 'block',
        opacity: '0',
        overflow: 'hidden',
        transition: 'opacity .2s ease',
      });
      panel.offsetHeight;
      panel.style.opacity = '1';
      document.body.style.overflow = 'hidden';
    } else {
      const cRect = container.getBoundingClientRect();
      const kRect = card.getBoundingClientRect();
      const t = kRect.top    - cRect.top;
      const l = kRect.left   - cRect.left;
      const r = cRect.right  - kRect.right;
      const b = cRect.bottom - kRect.bottom;

      Object.assign(panel.style, {
        position: 'absolute',
        borderRadius: '',
        display: 'block',
        transition: 'none',
        top: t + 'px', left: l + 'px', right: r + 'px', bottom: b + 'px',
        opacity: '0',
        overflow: 'hidden',
      });
      panel.dataset.closeTop    = String(t);
      panel.dataset.closeLeft   = String(l);
      panel.dataset.closeRight  = String(r);
      panel.dataset.closeBottom = String(b);

      panel.offsetHeight;

      Object.assign(panel.style, {
        transition: `top .4s ${EASING}, left .4s ${EASING}, right .4s ${EASING}, bottom .4s ${EASING}, opacity .3s ease`,
        top: '0', left: '0', right: '0', bottom: '0',
        opacity: '1',
      });

      // scroll services section into view (account for fixed nav)
      const sectionTop = container.getBoundingClientRect().top + window.scrollY - NAV_H - 16;
      window.scrollTo({ top: sectionTop, behavior: 'smooth' });
    }
  }

  function closePanel(panel: HTMLElement) {
    if (isMobile()) {
      Object.assign(panel.style, {
        transition: 'opacity .2s ease',
        opacity: '0',
      });
      panel.addEventListener('transitionend', () => {
        panel.style.display = 'none';
        panel.style.position = 'absolute';
        panel.style.borderRadius = '';
        document.body.style.overflow = '';
      }, { once: true });
    } else {
      const t = panel.dataset.closeTop    ?? '0';
      const l = panel.dataset.closeLeft   ?? '0';
      const r = panel.dataset.closeRight  ?? '0';
      const b = panel.dataset.closeBottom ?? '0';

      Object.assign(panel.style, {
        transition: `top .35s ${EASING}, left .35s ${EASING}, right .35s ${EASING}, bottom .35s ${EASING}, opacity .25s ease`,
        top: t + 'px', left: l + 'px', right: r + 'px', bottom: b + 'px',
        opacity: '0',
        overflow: 'hidden',
      });
      panel.addEventListener('transitionend', () => {
        panel.style.display = 'none';
      }, { once: true });
    }
  }

  document.querySelectorAll<HTMLElement>('.show-prices-btn').forEach(btn => {
    btn.addEventListener('click', () => openPanel(btn.dataset.serviceId!));
  });

  document.querySelectorAll<HTMLElement>('.close-prices-btn').forEach(btn => {
    btn.addEventListener('click', () => closePanel(btn.closest<HTMLElement>('.price-panel')!));
  });
</script>
