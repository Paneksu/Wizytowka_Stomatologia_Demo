---
const photos = [
  {
    src: 'https://gabinetwpasazu.pl/wp-content/uploads/2018/01/IMG_7003.jpg',
    alt: 'Gabinet stomatologiczny — wnętrze',
    span: 'lg:col-span-2',
  },
  {
    src: 'https://gabinetwpasazu.pl/wp-content/uploads/2018/01/IMG_6997.jpg',
    alt: 'Gabinet zabiegowy',
    span: '',
  },
  {
    src: 'https://gabinetwpasazu.pl/wp-content/uploads/2018/01/IMG_6996.jpg',
    alt: 'Fotel dentystyczny',
    span: '',
  },
  {
    src: 'https://gabinetwpasazu.pl/wp-content/uploads/2018/01/IMG_6995.jpg',
    alt: 'Sprzęt stomatologiczny',
    span: '',
  },
  {
    src: 'https://gabinetwpasazu.pl/wp-content/uploads/2018/01/IMG_7019.jpg',
    alt: 'Recepcja gabinetu',
    span: 'lg:col-span-2',
  },
  {
    src: 'https://gabinetwpasazu.pl/wp-content/uploads/2018/01/IMG_7018.jpg',
    alt: 'Poczekania',
    span: '',
  },
  {
    src: 'https://gabinetwpasazu.pl/wp-content/uploads/2018/01/IMG_7016.jpg',
    alt: 'Gabinet — szczegół',
    span: '',
  },
  {
    src: 'https://gabinetwpasazu.pl/wp-content/uploads/2018/01/IMG_7000.jpg',
    alt: 'Stanowisko lekarskie',
    span: '',
  },
  {
    src: 'https://gabinetwpasazu.pl/wp-content/uploads/2018/01/IMG_6998.jpg',
    alt: 'Gabinet — widok ogólny',
    span: '',
  },
];
---

<section id="galeria" class="py-20 lg:py-28 bg-cream-dark">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="max-w-xl mb-12">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4">Galeria</p>
      <h2 class="font-display text-4xl lg:text-5xl font-semibold text-ink leading-[1.1]">
        Nasz<br /><em class="italic font-normal">gabinet</em>
      </h2>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 auto-rows-[220px]">
      {photos.map(photo => (
        <div class={`relative overflow-hidden rounded-xl group ${photo.span}`}>
          <img
            src={photo.src}
            alt={photo.alt}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/25 transition-colors duration-300"></div>
          <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
            <p class="text-cream text-xs font-medium">{photo.alt}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
