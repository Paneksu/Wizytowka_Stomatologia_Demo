---
const pillars = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Bezpieczeństwo przede wszystkim',
    body: 'Sterylizacja instrumentów, jednorazowe materiały i rygorystyczne standardy higieny — Twoje zdrowie jest dla nas priorytetem.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: 'Twój czas jest cenny',
    body: 'Krótkie terminy, punktualne wizyty i elastyczne godziny pracy — dopasowujemy grafik do Twojego stylu życia.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>`,
    title: 'Leczenie bez stresu',
    body: 'Rozumiemy lęk dentystyczny. Pracujemy w spokojnym tempie, tłumaczymy każdy krok i dbamy o Twój komfort przez całą wizytę.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
    title: 'Nieustanny rozwój',
    body: 'Regularnie podnosimy kwalifikacje i inwestujemy w nowoczesny sprzęt, by oferować Ci najlepsze rozwiązania w stomatologii.',
  },
];
---

<section class="bg-cream-dark py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="max-w-xl mb-14">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4">Nasza obietnica</p>
      <h2 class="font-display text-4xl lg:text-5xl font-semibold text-ink leading-[1.1]">
        Opieka, na którą<br /><em class="italic font-normal">możesz liczyć</em>
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-6">
      {pillars.map(p => (
        <div class="flex flex-col gap-4">
          <div class="text-gold" set:html={p.icon} />
          <h3 class="text-base font-semibold text-ink leading-snug">{p.title}</h3>
          <p class="text-sm text-ink-muted leading-relaxed">{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
