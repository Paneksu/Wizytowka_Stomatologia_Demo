const all = [...doctors, ...team];
---

<section id="zespol" class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="max-w-xl mb-14">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4">Nasz zespół</p>
      <h2 class="font-display text-4xl lg:text-5xl font-semibold text-ink leading-[1.1]">
        Poznaj ludzi,<br /><em class="italic font-normal">którzy zadbają o Ciebie</em>
      </h2>
    </div>

    <div class="mb-14">
      <h3 class="text-xs font-semibold tracking-[0.15em] uppercase text-ink-muted mb-8">Lekarze stomatolodzy</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {doctors.map((p, i) => (
          <div class="person-card group flex flex-col gap-4 cursor-default" data-index={i}>
            <div class="relative overflow-hidden rounded-xl aspect-[3/4]">
              <img
                src={p.photo}
                alt={p.name}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                style={`object-position: ${p.pos}`}
                loading="lazy"
              />
            </div>
            <div>
              <p class="text-sm font-semibold text-ink leading-snug mb-0.5">{p.name}</p>
              <p class="text-xs font-medium text-gold mb-3">{p.role}</p>
              <p class="text-xs text-ink-muted leading-relaxed">{p.base}</p>
              <div class="bio-expand overflow-hidden">
                <p class="md:hidden text-xs text-ink-muted leading-relaxed">{p.extra}</p>
                <span class="bio-typed hidden md:block text-xs text-ink-muted leading-relaxed" data-text={p.extra} aria-hidden="true"></span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="pt-12 border-t border-border">
      <h3 class="text-xs font-semibold tracking-[0.15em] uppercase text-ink-muted mb-8">Higienistki i asystentki</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {team.map((p, i) => (
          <div class="person-card group flex flex-col gap-4 cursor-default" data-index={doctors.length + i}>
            <div class="relative overflow-hidden rounded-xl aspect-[3/4]">
              <img
                src={p.photo}
                alt={p.name}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                style={`object-position: ${p.pos}`}
                loading="lazy"
              />
            </div>
            <div>
              <p class="text-sm font-semibold text-ink leading-snug mb-0.5">{p.name}</p>
              <p class="text-xs font-medium text-gold mb-3">{p.role}</p>
              <p class="text-xs text-ink-muted leading-relaxed">{p.base}</p>
              <div class="bio-expand overflow-hidden">
                <p class="md:hidden text-xs text-ink-muted leading-relaxed">{p.extra}</p>
                <span class="bio-typed hidden md:block text-xs text-ink-muted leading-relaxed" data-text={p.extra} aria-hidden="true"></span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @media (min-width: 768px) {
    .bio-expand {
      height: 0;
      transition: height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    }
  }
  .bio-cursor::after {
    content: '|';
    animation: blink 0.7s step-end infinite;
    color: var(--color-gold);
    margin-left: 1px;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.person-card').forEach(card => {
    const expand = card.querySelector<HTMLElement>('.bio-expand');
    const typed  = card.querySelector<HTMLElement>('.bio-typed');
    if (!expand || !typed) return;

    // tylko na urządzeniach z hover (desktop)
    if (!window.matchMedia('(hover: hover)').matches) return;

    const fullText = typed.dataset.text ?? '';
    let timer: ReturnType<typeof setTimeout> | null = null;
    let idx = 0;

    // zmierz docelową wysokość raz — bez zmiany layoutu
    typed.textContent = fullText;
    const targetH = expand.scrollHeight;
    typed.textContent = '';

    function clearTimer() {
      if (timer !== null) { clearTimeout(timer); timer = null; }
    }

    function type() {
      if (idx >= fullText.length) {
        typed.classList.remove('bio-cursor');
        return;
      }
      typed.textContent = fullText.slice(0, ++idx);
      timer = setTimeout(type, 6);
    }

    card.addEventListener('mouseenter', () => {
      clearTimer();
      idx = 0;
      typed.textContent = '';
      typed.classList.add('bio-cursor');
      // jedna płynna animacja wysokości do docelowej pozycji
      expand.style.height = targetH + 'px';
      timer = setTimeout(type, 40);
    });

    card.addEventListener('mouseleave', () => {
      clearTimer();
      typed.classList.remove('bio-cursor');
      typed.textContent = '';
      idx = 0;
      expand.style.height = '0px';
    });
  });
</script>
