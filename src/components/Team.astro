    photo: 'https://gabinetwpasazu.pl/wp-content/uploads/2018/03/monika.jpg',
    pos: '22% top',
  },
  {
    name: 'Justyna Grzonka',
    role: 'Higienistka stomatologiczna',
    base: 'Ukończyła szkołę asystentek i higienistek stomatologicznych. Czynnie asystuje lekarzom przy zabiegach, jak i samodzielnie wykonuje niektóre zabiegi.',
    extra: ' Bardzo ceni sobie kontakt z ludźmi. Stale podnosi swoje umiejętności i kwalifikacje.',
    photo: 'https://gabinetwpasazu.pl/wp-content/uploads/2018/03/justyna_.jpg',
    pos: '25% top',
  },
  {
    name: 'Anna Korolewicz',
    role: 'Asystentka stomatologiczna',
    base: 'Najbardziej doświadczona asystentka w gabinecie. Czynnie asystuje lekarzom.',
    extra: ' Wykonuje również samodzielnie zabiegi higienizacyjne. Lakowanie pierwszych zębów trzonowych u dzieci zawsze jest zakończone pięknym uśmiechem. Stale poszerza swoją wiedzę.',
    photo: 'https://gabinetwpasazu.pl/wp-content/uploads/2018/03/ania.jpg',
