---
const features = [
  'Delikatne, bezstresowe leczenie dla całej rodziny',
  'Stomatologia dziecięca i dorosłych',
  'Implanty, protetyka i ortodoncja',
  'Nowoczesny sprzęt — RTG, mikroskop, CBCT',
  'Krótkie terminy, w tym nagłe przypadki',
];
---

<section class="min-h-screen pt-16 grid lg:grid-cols-2">
  <div class="flex flex-col justify-center px-8 md:px-14 lg:px-16 xl:px-24 py-12 sm:py-20 lg:py-0 order-1">
    <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-6">
      Jastrzębie-Zdrój · Pasaż 24H
    </p>

    <h1 class="font-display text-4xl sm:text-5xl md:text-6xl xl:text-7xl font-semibold text-ink leading-[1.08] mb-4 sm:mb-6">
      Twój uśmiech<br />
      <em class="italic font-normal">jest bezcenny</em>
    </h1>

    <p class="text-ink-muted text-base leading-relaxed mb-6 sm:mb-8 max-w-md">
      Dla Ciebie i Twoich bliskich. Od niego wszystko się zaczyna.
      Profesjonalna opieka stomatologiczna w Jastrzębiu-Zdroju.
    </p>

    <ul class="space-y-3 mb-8 sm:mb-10">
      {features.map(f => (
        <li class="flex items-center gap-3 text-ink-muted text-sm">
          <span class="w-1.5 h-1.5 rounded-full bg-gold flex-shrink-0"></span>
          {f}
        </li>
      ))}
    </ul>

    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <a
        href="#kontakt"
        class="bg-ink text-cream text-sm font-medium px-8 py-4 rounded-full hover:bg-ink/80 transition-colors duration-200"
      >
        Umów wizytę
      </a>
      <div class="flex flex-col gap-1">
        <a href="tel:+48324731902" class="flex items-center gap-2.5 text-sm font-medium text-ink hover:text-gold transition-colors duration-200">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11 19.79 19.79 0 01.01 2.4 2 2 0 012 .18h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
          </svg>
          32 47 31 902
        </a>
        <a href="tel:+48533311699" class="flex items-center gap-2.5 text-sm text-ink-muted hover:text-ink transition-colors duration-200 pl-[22px]">
          533 311 699
        </a>
      </div>
    </div>
  </div>

  <div class="relative h-72 sm:h-96 lg:h-auto order-2 overflow-hidden">
    <img
      src="https://gabinetwpasazu.pl/wp-content/uploads/2018/01/IMG_7003-1024x682.jpg"
      alt="Gabinet Stomatologiczny w Pasażu 24H — Jastrzębie-Zdrój"
      class="w-full h-full object-cover" style="object-position: 25% center"
      loading="eager"
    />
    <div class="absolute inset-0 bg-ink/10"></div>
    <div class="absolute bottom-8 left-8 right-8 hidden lg:block">
      <div class="bg-cream/92 backdrop-blur-sm rounded-2xl px-6 py-4 border border-border/60">
        <p class="text-xs text-ink-muted mb-0.5">Lokalizacja</p>
        <p class="text-sm font-semibold text-ink">ul. Harcerska 2A, Jastrzębie-Zdrój</p>
        <p class="text-xs text-ink-muted mt-0.5">Pasaż 24H · parking przy wejściu</p>
      </div>
    </div>
  </div>
</section>
