---
const reviews = [
  {
    quote: 'Wspaniałe miejsce, serdecznie polecam. Miła, przyjazna atmosfera. Byłam tam wielokrotnie z dzieckiem i dzięki taktownemu i spokojnemu podejściu lekarzy, syn przełamał lęk przed wizytami u stomatologa.',
    author: 'Joanna',
    date: 'lipiec 2025',
    stars: 5,
  },
  {
    quote: 'Cała moja rodzina korzystała i korzysta z usług gabinetu od ponad 20 lat. Profesjonalnie, bezpiecznie, bezbolesnie, zawsze z troską o pacjenta.',
    author: 'Jadwiga M.',
    date: 'styczeń 2022',
    stars: 5,
  },
  {
    quote: 'Polecam serdecznie — lekarz ma anielską cierpliwość do małego pacjenta. Swoim miłym nastawieniem do córki przekonał ją, że leczenie zębów nie musi boleć.',
    author: 'Waleria',
    date: 'marzec 2021',
    stars: 5,
  },
];
---

<section class="py-20 lg:py-28 bg-ink overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-14">
      <div class="max-w-xl">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4">Opinie pacjentów</p>
        <h2 class="font-display text-4xl lg:text-5xl font-semibold text-cream leading-[1.1]">
          Co mówią<br /><em class="italic font-normal text-cream/70">nasi pacjenci</em>
        </h2>
      </div>
      <div class="flex items-center gap-3 text-cream/60">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-gold"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <span class="text-sm font-medium text-cream">4.2 / 5.0</span>
        <span class="text-sm">· Recenzje Google</span>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {reviews.map(r => (
        <div class="bg-cream/8 border border-cream/10 rounded-2xl p-8 flex flex-col gap-6">
          <div class="flex gap-1">
            {Array.from({ length: r.stars }).map(() => (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-gold">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>
          <p class="text-cream/80 text-sm leading-relaxed flex-1">
            &ldquo;{r.quote}&rdquo;
          </p>
          <div class="border-t border-cream/10 pt-5 flex items-center justify-between">
            <p class="text-sm font-semibold text-cream">{r.author}</p>
            <p class="text-xs text-cream/40">{r.date}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
